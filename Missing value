class Solution {
    public int[] findMissingAndRepeatedValues(int[][] grid) {
        int n = grid.length;
        int totalElements = n * n;
        
        // Frequency array to store counts of numbers from 1 to n^2
        int[] counts = new int[totalElements + 1];
        
        // Step 1: Count frequencies of each number in the grid
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                counts[grid[i][j]]++;
            }
        }
        
        int repeating = -1;
        int missing = -1;
        
        // Step 2: Identify the repeating and missing numbers
        for (int i = 1; i <= totalElements; i++) {
            if (counts[i] == 2) {
                repeating = i;
            } else if (counts[i] == 0) {
                missing = i;
            }
            
            // Optimization: Break early if both are found
            if (repeating != -1 && missing != -1) {
                break;
            }
        }
        
        return new int[]{repeating, missing};
    }
}
